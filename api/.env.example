# ============================================================
# NovaRetail Analytics — API REST
# Copia este archivo como .env y completa los valores
# ============================================================

# Puerto del servidor
PORT=3000

# Conexión a PostgreSQL
DATABASE_URL=postgresql://usuario:contrasena@localhost:5432/novaretail

# Secreto para verificar JWT (debe coincidir con el servicio que emite los tokens)
JWT_SECRET=cambia_este_secreto_seguro

# Ruta al binario Python del venv (opcional, se detecta automáticamente)
# Windows:
# PYTHON_BIN=..\etl\venv\Scripts\python.exe
# Linux/Mac:
# PYTHON_BIN=../etl/venv/bin/python3
